# Jira Configuration
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_USERNAME=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_BOARD_ID=your-board-id

# Google Sheets Configuration
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id
GOOGLE_SHEETS_SHEET_NAME=Test Scenarios
GOOGLE_SERVICE_ACCOUNT_KEY=path/to/service-account-key.json

# AI Configuration (Choose one)
# Option 1: Groq (FREE, FAST) - Recommended
# Get your API key from: https://console.groq.com/keys
OPENAI_API_KEY=your-groq-api-key
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# Option 2: OpenAI (PAID)
# Get your API key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4

# Morpheus MCP Configuration
MORPHEUS_MCP_URL=http://localhost:8080
MORPHEUS_MCP_TOKEN=your-morpheus-token

# Server Configuration
PORT=4007
NODE_ENV=development
LOG_LEVEL=info

# Frontend Configuration (for development)
VITE_API_BASE_URL=http://localhost:4007